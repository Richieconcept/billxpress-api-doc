        "costPrice": 7000,
        "sellingPrice": 8000,
        "profit": 1000,
        "lossAmount": 132,
        "lostProfit": 12,
        "lossPercentage": 1.62,
        "profitMarginPercentage": 12.5,
        "successfulCount": 6,
        "failedCount": 0,
        "reversedCount": 1,
        "totalCount": 7,
        "averageSellingPrice": 1333.33
      },
      {
        "service": "airtime",
        "earned": 3000,
        "revenue": 3000,
        "costPrice": 2800,
        "sellingPrice": 3000,
        "profit": 200,
        "lossAmount": 0,
        "lostProfit": 0,
        "lossPercentage": 0,
        "profitMarginPercentage": 6.67,
        "successfulCount": 4,
        "failedCount": 0,
        "reversedCount": 0,
        "totalCount": 4,
        "averageSellingPrice": 750
      },
      {
        "service": "social_growth",
        "earned": 4000,
        "revenue": 4000,
        "costPrice": 2200,
        "sellingPrice": 4000,
        "profit": 1800,
        "lossAmount": 0,
        "lostProfit": 0,
