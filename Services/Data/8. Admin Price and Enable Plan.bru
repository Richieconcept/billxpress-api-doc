meta {
  name: 8. Admin Price and Enable Plan
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/api/v1/admin/services/data/plans/{{dataPlanId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{authToken}}
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "ourPrice": 409,
    "isEnabled": true,
    "dataType": "Awoof",
    "allowHostedSim": true,
    "allowWalletFallback": false
  }
}

