meta {
  name: 2. Airtime Quote
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/services/airtime/quote
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{authToken}}
}

